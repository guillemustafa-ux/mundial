# ── Requeridos ────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
FOOTBALL_API_KEY=

# ── API Football (defaults) ───────────────────────────────────────────────
FOOTBALL_BASE_URL=https://v3.football.api-sports.io
WC_LEAGUE_ID=1
WC_SEASON=2026
ARGENTINA_TEAM_ID=6
DAILY_API_BUDGET=100

# ── worldcup26.ir (gratis, sin key) ──────────────────────────────────────
WORLDCUP26_BASE_URL=https://worldcup26.ir

# ── BALLDONTLIE (free tier — registrarse en balldontlie.io) ──────────────
BALLDONTLIE_API_KEY=
BALLDONTLIE_ENABLED=false

# ── Odds APIs (opcional) ─────────────────────────────────────────────────
ODDS_ENABLED=false
ODDS_API_IO_KEY=          # odds-api.io (265+ bookmakers)
ODDS_API_KEY=             # the-odds-api.com (fallback)

# ── Configuración general ─────────────────────────────────────────────────
DB_PATH=/data/worldcup.db
DISPLAY_TZ=America/Argentina/Buenos_Aires
LIVE_POLL_INTERVAL=120
LIVE_POLL_LEAD_MINUTES=30

# ── Admin (opcional) ─────────────────────────────────────────────────────
ADMIN_USER_ID=
